{
  "schemaVersion": 1,
  "id": "homepage-editor",
  "title": "Homepage Editor",
  "description": "Homepage Editor drop-in module for the white-label contractor platform.",
  "version": "1.0.0",
  "category": "Admin",
  "icon": "\ud83c\udfe0",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "Homepage Editor",
    "mobileLabel": "Homepage",
    "sortOrder": 120
  },
  "frontend": {
    "basePath": "/modules/homepage-editor/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "homepage-editor"
  },
  "backend": {
    "functions": [
      {
        "name": "homepage-editor",
        "method": [
          "GET",
          "POST",
          "PATCH"
        ],
        "route": "/api/modules/homepage-editor/records",
        "file": "backend/handler.mjs"
      }
    ]
  },
  "permissions": [
    {
      "key": "homepage.view",
      "label": "Homepage View",
      "group": "Homepage Editor",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "homepage.manage",
      "label": "Homepage Manage",
      "group": "Homepage Editor",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [],
  "settings": {
    "ownerAlwaysVisible": true
  }
}