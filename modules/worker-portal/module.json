{
  "id": "worker-portal",
  "name": "Worker Portal",
  "icon": "briefcase",
  "version": "1.0.0",
  "enabledByDefault": true,
  "category": "Portal",
  "route": "/dashboard/modules/worker-portal",
  "apiBase": "/api/modules/worker-portal",
  "nav": {
    "sidebar": true,
    "mobile": true,
    "order": 40
  },
