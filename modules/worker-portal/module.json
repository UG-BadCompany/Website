      "action": "create",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "worker-portal.update",
      "action": "update",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "worker-portal.delete",
      "action": "delete",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "worker-portal.approve",
      "action": "approve",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "worker-portal.export",
      "action": "export",
      "roles": [
        "owner",
        "admin"
      ]
    }
  ],
  "emptyState": {
