{
  "schemaVersion": 1,
  "id": "users-permissions",
  "title": "Users & Permissions",
  "description": "Drop-in module for users & permissions.",
  "version": "1.0.0",
  "category": "System",
  "icon": "\ud83d\udd10",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": false,
    "label": "Users & Permissions",
    "mobileLabel": "Users",
    "sortOrder": 100
  },
  "frontend": {
    "basePath": "/modules/users-permissions/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "users-permissions"
  },
  "backend": {
    "functions": [
      {
        "name": "users-permissions",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/users-permissions/records",
        "file": "backend/functions/records.mjs",
        "permission": "users.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "users.view",
      "label": "Users View",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "users.manage",
      "label": "Users Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "roles.manage",
      "label": "Roles Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
