{
  "schemaVersion": 1,
  "id": "work-orders",
  "title": "Work Orders",
  "description": "Assignment, scheduling, completion, review, and archive flow.",
  "version": "1.0.0",
  "category": "Operations",
  "icon": "🛠️",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "Work Orders",
    "mobileLabel": "Work",
    "sortOrder": 20
  },
  "frontend": {
    "basePath": "/modules/work-orders/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "work-orders"
  },
  "backend": {
    "functions": [
      {
        "name": "work-orders",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/work-orders/records",
        "file": "backend/functions/work-orders.mjs"
      }
    ]
  },
  "permissions": [
    {
      "key": "work-orders.view",
      "label": "View Work Orders",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    },
    {
      "key": "work-orders.manage",
      "label": "Manage Work Orders",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [],
  "settings": {
    "dropIn": true
  }
}