{
  "schemaVersion": 1,
  "id": "reports",
  "title": "Reports",
  "description": "Drop-in module for reports.",
  "version": "1.0.0",
  "category": "Insights",
  "icon": "\ud83d\udcca",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": false,
    "label": "Reports",
    "mobileLabel": "Reports",
    "sortOrder": 140
  },
  "frontend": {
    "basePath": "/modules/reports/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "reports"
  },
  "backend": {
    "functions": [
      {
        "name": "reports",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/reports/records",
        "file": "backend/functions/records.mjs",
        "permission": "reports.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "reports.view",
      "label": "Reports View",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
