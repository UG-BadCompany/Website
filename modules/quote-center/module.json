{
  "id": "quote-center",
  "version": "1.0.0",
  "name": "Estimate & Quote Center",
  "description": "Drop-in module for Estimate & Quote Center.",
  "category": "Operations",
  "minimumPlatform": "1.0.0",
  "status": "stable",
  "enabledByDefault": true,
  "hidden": false,
  "beta": false,
  "experimental": false,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "label": "Quote Center",
    "icon": "◼",
    "order": 1
  },
  "permissions": [
    {
      "key": "quote-center.view",
      "label": "Use Estimate & Quote Center",
      "group": "Estimate & Quote Center",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    }
  ],
  "dependencies": [],
  "frontend": {
    "entry": "/modules/quote-center/frontend/module.js",
    "style": "/modules/quote-center/frontend/module.css"
  },
  "api": {
    "handler": "modules/quote-center/backend/api.mjs",
    "routes": [
      {
        "method": [
          "GET",
          "POST"
        ],
        "path": "/records",
        "permission": "quote-center.view"
      }
    ]
  },
  "homepageSections": [],
  "workflows": [
    "request.created",
    "quote.sent",
    "quote.accepted"
  ]
}