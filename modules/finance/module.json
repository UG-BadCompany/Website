{
  "schemaVersion": 1,
  "id": "finance",
  "title": "Finance",
  "description": "Drop-in module for finance.",
  "version": "1.0.0",
  "category": "Finance",
  "icon": "\ud83d\udcc8",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "Finance",
    "mobileLabel": "Finance",
    "sortOrder": 80
  },
  "frontend": {
    "basePath": "/modules/finance/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "finance"
  },
  "backend": {
    "functions": [
      {
        "name": "finance",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/finance/records",
        "file": "backend/functions/records.mjs",
        "permission": "finance.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "finance.view",
      "label": "Finance View",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    },
    {
      "key": "finance.manage",
      "label": "Finance Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
