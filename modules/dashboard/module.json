  "permissions": [
    {
      "key": "dashboard.view",
      "action": "view",
      "roles": [
        "owner",
        "admin",
        "manager",
        "worker",
        "client"
      ]
    },
    {
      "key": "dashboard.create",
      "action": "create",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "dashboard.update",
      "action": "update",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "dashboard.delete",
      "action": "delete",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "dashboard.approve",
      "action": "approve",
      "roles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "dashboard.export",
      "action": "export",
      "roles": [
        "owner",
        "admin"
      ]
    }
  ],
  "emptyState": {
    "title": "No Dashboard / Overview records yet",
    "body": "Use Dashboard / Overview to manage this part of your contractor CMMS workflow.",
    "action": "Open Dashboard / Overview"
