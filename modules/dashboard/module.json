{
  "id": "dashboard",
  "name": "Dashboard / Overview",
  "icon": "layout-dashboard",
  "version": "1.0.0",
  "enabledByDefault": true,
  "category": "Operations",
  "route": "/dashboard/modules/dashboard",
  "apiBase": "/api/modules/dashboard",
  "nav": {
    "sidebar": true,
    "mobile": true,
    "order": 10
  },
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
