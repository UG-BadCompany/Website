{
  "schemaVersion": 1,
  "id": "platform-health",
  "title": "Platform Health",
  "description": "Drop-in module for platform health.",
  "version": "1.0.0",
  "category": "System",
  "icon": "\ud83d\udfe2",
  "enabledByDefault": true,
  "workspaces": [
    "owner"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": false,
    "label": "Platform Health",
    "mobileLabel": "Platform",
    "sortOrder": 160
  },
  "frontend": {
    "basePath": "/modules/platform-health/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "platform-health"
  },
  "backend": {
    "functions": [
      {
        "name": "platform-health",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/platform-health/records",
        "file": "backend/functions/records.mjs",
        "permission": "platform.health.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "platform.health.view",
      "label": "Platform Health View",
      "defaultRoles": [
        "owner"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
