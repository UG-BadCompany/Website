{
  "schemaVersion": 1,
  "id": "ai-photo-estimate",
  "title": "AI Photo Estimate",
  "description": "Photo-based estimating workflow using shared AI service with honest fallback.",
  "version": "1.0.0",
  "category": "AI",
  "icon": "📸",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
