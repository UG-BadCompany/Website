    {
      "key": "ai-photo-estimate.use",
      "label": "Use AI Photo Estimate",
      "group": "AI Photo Estimate",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    }
  ],
  "dependencies": [],
  "frontend": {
    "entry": "/modules/ai-photo-estimate/frontend/module.js",
    "style": "/modules/ai-photo-estimate/frontend/module.css"
  },
  "api": {
    "handler": "modules/ai-photo-estimate/backend/api.mjs",
    "routes": [
      {
        "method": [
          "GET",
          "POST"
        ],
        "path": "/records",
        "permission": "ai-photo-estimate.use"
      }
    ]
  },
  "homepageSections": [],
  "workflows": []
}