{
  "id": "ai-photo-estimate",
  "version": "1.0.0",
  "name": "AI Photo Estimate",
  "description": "Drop-in module for AI Photo Estimate.",
  "category": "AI",
  "minimumPlatform": "1.0.0",
  "status": "stable",
  "enabledByDefault": true,
  "hidden": false,
  "beta": false,
  "experimental": false,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "label": "AI Photo Estimate",
    "icon": "◼",
    "order": 2
  },
