{
  "schemaVersion": 1,
  "id": "ai-photo-estimate",
  "title": "AI Photo Estimate",
  "description": "Drop-in module for ai photo estimate.",
  "version": "1.0.0",
  "category": "AI",
  "icon": "\ud83d\udcf8",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "AI Photo Estimate",
    "mobileLabel": "AI",
    "sortOrder": 20
  },
  "frontend": {
    "basePath": "/modules/ai-photo-estimate/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "ai-photo-estimate"
  },
  "backend": {
    "functions": [
      {
        "name": "ai-photo-estimate",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/ai-photo-estimate/records",
        "file": "backend/functions/records.mjs",
        "permission": "ai.photo-estimate.use"
      }
    ]
  },
  "permissions": [
    {
      "key": "ai.photo-estimate.use",
      "label": "Ai Photo Estimate Use",
      "defaultRoles": [
        "owner",
        "admin",
        "manager",
        "worker",
        "client"
      ]
    },
    {
      "key": "ai.photo-estimate.manage",
      "label": "Ai Photo Estimate Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [
    "customers",
    "estimate-quote-center"
  ],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true,
    "requiresOpenAI": true
  }
}
