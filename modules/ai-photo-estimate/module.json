  "frontend": {
    "basePath": "/modules/ai-photo-estimate/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "ai-photo-estimate"
  },
  "backend": {
    "functions": [
      {
        "name": "ai-photo-estimate",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/ai-photo-estimate/records",
        "file": "backend/functions/ai-photo-estimate.mjs"
      }
    ]
