  "permissions": [
    {
      "key": "ai-photo-estimate.view",
      "label": "View AI Photo Estimate",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    },
    {
      "key": "ai-photo-estimate.manage",
      "label": "Manage AI Photo Estimate",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [],
  "settings": {
    "dropIn": true
  }
}