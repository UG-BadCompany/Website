{
  "schemaVersion": 1,
  "id": "customers",
  "title": "Customers",
  "description": "Drop-in module for customers.",
  "version": "1.0.0",
  "category": "CRM",
  "icon": "\ud83d\udc65",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "Customers",
    "mobileLabel": "Customers",
    "sortOrder": 90
  },
  "frontend": {
    "basePath": "/modules/customers/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "customers"
  },
  "backend": {
    "functions": [
      {
        "name": "customers",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/customers/records",
        "file": "backend/functions/records.mjs",
        "permission": "customers.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "customers.view",
      "label": "Customers View",
      "defaultRoles": [
        "owner",
        "admin",
        "manager",
        "worker"
      ]
    },
    {
      "key": "customers.manage",
      "label": "Customers Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
