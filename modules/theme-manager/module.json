{
  "schemaVersion": 1,
  "id": "theme-manager",
  "title": "Theme Manager",
  "description": "Drop-in module for theme manager.",
  "version": "1.0.0",
  "category": "System",
  "icon": "\ud83c\udfa8",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": false,
    "label": "Theme Manager",
    "mobileLabel": "Theme",
    "sortOrder": 110
  },
  "frontend": {
    "basePath": "/modules/theme-manager/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "theme-manager"
  },
  "backend": {
    "functions": [
      {
        "name": "theme-manager",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/theme-manager/records",
        "file": "backend/functions/records.mjs",
        "permission": "theme.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "theme.view",
      "label": "Theme View",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    },
    {
      "key": "theme.manage",
      "label": "Theme Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
