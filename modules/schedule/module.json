        "owner",
        "admin",
        "manager",
        "worker"
      ]
    },
    {
      "key": "schedule.manage",
      "label": "Schedule Manage",
      "group": "Schedule",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
