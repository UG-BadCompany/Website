{
  "schemaVersion": 1,
  "id": "schedule",
  "title": "Schedule",
  "description": "Drop-in module for schedule.",
  "version": "1.0.0",
  "category": "Operations",
  "icon": "\ud83d\udcc5",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "Schedule",
    "mobileLabel": "Schedule",
    "sortOrder": 50
  },
  "frontend": {
    "basePath": "/modules/schedule/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "schedule"
  },
  "backend": {
    "functions": [
      {
        "name": "schedule",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/schedule/records",
        "file": "backend/functions/records.mjs",
        "permission": "schedule.view"
      }
    ]
  },
  "permissions": [
    {
      "key": "schedule.view",
      "label": "Schedule View",
      "defaultRoles": [
        "owner",
        "admin",
        "manager",
        "worker",
        "client"
      ]
    },
    {
      "key": "schedule.manage",
      "label": "Schedule Manage",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [
    "record:viewed",
    "record:saved"
  ],
  "settings": {
    "dropIn": true
  }
}
