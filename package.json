{
  "name": "contractor-cmms-ai-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/prebuild-netlify-migrations.cjs",
    "build": "node scripts/discover-modules.mjs && node scripts/generate-bootstrap-config.mjs && node scripts/build-static-site.mjs",
    "postbuild": "node scripts/check-netlify-functions.mjs && node scripts/ensure-netlify-out.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify:all": "node scripts/verify-all.mjs",
    "audit:all": "node scripts/audit-all.mjs"
  },
  "dependencies": {
    "@netlify/database": "latest",
    "pg": "latest"
  },
  "devDependencies": {}
}
