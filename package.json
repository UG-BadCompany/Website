{
  "name": "ta-contracting-website",
  "version": "1.0.0",
  "private": true,
  "description": "Deployable T&A Contracting website shell for Netlify.",
  "scripts": {
    "build": "node scripts/build-static-site.mjs",
    "postbuild": "node scripts/check-netlify-functions.mjs && node scripts/ensure-netlify-out.mjs",
    "start": "node scripts/serve-static-site.mjs",
    "test": "node --test",
    "prebuild": "node scripts/prebuild-netlify-migrations.cjs",
    "audit:phase8": "node scripts/audit-phase8.cjs",
    "audit:phase9": "node scripts/audit-phase9-routes.mjs",
    "audit:phase10": "node scripts/audit-phase10-header.mjs"
  },
  "engines": {
    "node": ">=20.12.2"
  },
  "dependencies": {
    "@netlify/database": "latest"
  },
  "audit:phase11": "node scripts/audit-phase11-finish.mjs",
  "audit:phase12": "node scripts/audit-phase12-client-worker.mjs",
  "audit:phase13": "node scripts/audit-phase13-public-style.mjs",
  "audit:phase14": "node scripts/audit-phase14-readability.mjs"
}
