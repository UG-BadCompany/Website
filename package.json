{
  "name": "white-label-contractor-cmms",
  "version": "1.0.0",
  "private": true,
  "description": "White-label AI contractor CMMS and quoting platform for Netlify.",
  "scripts": {
    "build": "node scripts/build-static-site.mjs",
    "postbuild": "node scripts/check-netlify-functions.mjs && node scripts/ensure-netlify-out.mjs",
    "start": "node scripts/serve-static-site.mjs",
    "test": "npm run audit:all",
    "test:browser": "node --test tests/dashboard-workflow.spec.mjs tests/public-pages.spec.mjs tests/inventory-workflow.spec.mjs tests/quote-editor.spec.mjs",
    "test:e2e-workflows": "node --test tests/e2e-business-workflows.spec.mjs",
    "test:work-order-closeout": "node --test tests/work-order-closeout.spec.mjs",
    "test:sidebar-workspaces": "node --test tests/sidebar-workspaces.spec.mjs",
    "test:mobile-ux": "node --test tests/mobile-ux.spec.mjs",
    "test:module-completion": "node --test tests/module-completion.spec.mjs",
    "test:all": "npm run audit:all",
    "audit:dead-buttons": "node scripts/audit-dead-buttons.mjs",
    "audit:mobile-ux": "node scripts/audit-mobile-ux.mjs",
    "audit:module-completion": "node scripts/audit-module-completion.mjs",
    "audit:ui-consistency": "node scripts/audit-ui-consistency.mjs",
    "audit:all": "node scripts/audit-all.mjs",
    "verify:all": "node scripts/verify-all.mjs"
  },
  "engines": {
    "node": ">=20.12.2"
  },
  "dependencies": {
    "@netlify/database": "latest"
  }
}
