{
  "name": "ta-contracting-website",
  "version": "2.0.0",
  "private": true,
  "description": "Full rewritten T&A Contracting website with AI quote drafting for Netlify.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-static-site.mjs",
    "postbuild": "node scripts/check-netlify-functions.mjs && node scripts/ensure-netlify-out.mjs",
    "start": "node scripts/serve-static-site.mjs",
    "test": "node --test",
    "prebuild": "node scripts/prebuild-netlify-migrations.cjs"
  },
  "engines": {
    "node": ">=20.12.2"
  },
  "dependencies": {
    "@netlify/database": "latest",
    "@netlify/blobs": "latest"
  }
}