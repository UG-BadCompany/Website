{
  "name": "ta-contracting-website",
  "version": "1.0.0",
  "private": true,
  "description": "Deployable T&A Contracting website shell for Netlify.",
  "scripts": {
    "build": "node scripts/build-static-site.mjs",
    "postbuild": "node scripts/check-netlify-functions.mjs && node scripts/ensure-netlify-out.mjs",
    "start": "node scripts/serve-static-site.mjs",
    "test": "node --test",
    "prebuild": "node scripts/prebuild-netlify-migrations.cjs",
    "audit:phase8": "node scripts/audit-phase8.cjs",
    "audit:phase9": "node scripts/audit-phase9-routes.mjs",
    "audit:phase10": "node scripts/audit-phase10-header.mjs"
  },
  "engines": {
    "node": ">=20.12.2"
  },
  "dependencies": {
    "@netlify/database": "latest"
  },
  "audit:phase11": "node scripts/audit-phase11-finish.mjs",
  "audit:phase12": "node scripts/audit-phase12-client-worker.mjs",
  "audit:phase13": "node scripts/audit-phase13-public-style.mjs",
  "audit:phase14": "node scripts/audit-phase14-readability.mjs",
  "audit:phase15": "node scripts/audit-phase15-home-style.mjs",
  "audit:phase16": "node scripts/audit-phase16-portal-grid.mjs",
  "audit:phase17": "node scripts/audit-phase17-ai-accuracy.mjs",
  "audit:phase18": "node scripts/audit-phase18-supplier-pricing.mjs",
  "audit:phase19": "node scripts/audit-phase19-worker-mobile.mjs",
  "audit:phase20": "node scripts/audit-phase20-troubleshooting.mjs",
  "audit:phase21": "node scripts/audit-phase21-work-order-automation.mjs",
  "audit:phase22": "node scripts/audit-phase22-payments.mjs",
  "audit:phase23": "node scripts/audit-phase23-customer-experience.mjs",
  "audit:phase24": "node scripts/audit-phase24-photo-documentation.mjs",
  "audit:phase25": "node scripts/audit-phase25-inventory-assets.mjs",
  "audit:phase26": "node scripts/audit-phase26-smart-scheduling.mjs",
  "audit:phase27": "node scripts/audit-phase27-maintenance-plans.mjs"
}