{
  "schemaVersion": 1,
  "id": "invoices",
  "title": "Invoices & Payments",
  "description": "Invoice generation, Square payment link support, paid status, and archive.",
  "version": "1.0.0",
  "category": "Finance",
  "icon": "💳",
  "enabledByDefault": true,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "showInSidebar": true,
    "showInMobileNav": true,
    "label": "Invoices & Payments",
    "mobileLabel": "Invoices",
    "sortOrder": 30
  },
  "frontend": {
    "basePath": "/modules/invoices/frontend",
    "entry": "module.js",
    "html": "module.html",
    "css": "module.css",
    "registerId": "invoices"
  },
  "backend": {
    "functions": [
      {
        "name": "invoices",
        "method": [
          "GET",
          "POST"
        ],
        "route": "/api/modules/invoices/records",
        "file": "backend/functions/invoices.mjs"
      }
    ]
  },
  "permissions": [
    {
      "key": "invoices.view",
      "label": "View Invoices & Payments",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    },
    {
      "key": "invoices.manage",
      "label": "Manage Invoices & Payments",
      "defaultRoles": [
        "owner",
        "admin"
      ]
    }
  ],
  "dependencies": [],
  "workflowEvents": [],
  "settings": {
    "dropIn": true
  }
}