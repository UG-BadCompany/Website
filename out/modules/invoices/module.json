{
  "id": "invoices",
  "version": "1.0.0",
  "name": "Invoices",
  "description": "Drop-in module for Invoices.",
  "category": "Operations",
  "minimumPlatform": "1.0.0",
  "status": "stable",
  "enabledByDefault": true,
  "hidden": false,
  "beta": false,
  "experimental": false,
  "workspaces": [
    "owner",
    "admin",
    "manager",
    "worker",
    "client"
  ],
  "nav": {
    "label": "Invoices",
    "icon": "◼",
    "order": 7
  },
  "permissions": [
    {
      "key": "invoices.view",
      "label": "Use Invoices",
      "group": "Invoices",
      "defaultRoles": [
        "owner",
        "admin",
        "manager"
      ]
    }
  ],
  "dependencies": [],
  "frontend": {
    "entry": "/modules/invoices/frontend/module.js",
    "style": "/modules/invoices/frontend/module.css"
  },
  "api": {
    "handler": "modules/invoices/backend/api.mjs",
    "routes": [
      {
        "method": [
          "GET",
          "POST"
        ],
        "path": "/records",
        "permission": "invoices.view"
      }
    ]
  },
  "homepageSections": [],
  "workflows": []
}