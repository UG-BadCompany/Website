# Site
SITE_URL=https://your-domain.example

# Netlify Database / Postgres
# Netlify Database will provide the actual connection values in Netlify.
# Do not expose database credentials in client-side JavaScript.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Auth provider for the single-login portal (Auth0, Clerk, or another provider)
AUTH_PROVIDER=auth0
AUTH_ISSUER_URL=https://your-auth-domain.example
AUTH_CLIENT_ID=replace-with-client-id
AUTH_CLIENT_SECRET=replace-with-client-secret
AUTH_SESSION_SECRET=replace-with-random-session-secret
AUTH_SESSION_COOKIE_NAME=ta_session
AUTH_SESSION_TTL_DAYS=14
MAGIC_LINK_TTL_MINUTES=20
MAGIC_LINK_FROM_EMAIL=portal@your-domain.example

# Future integrations
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
RESEND_API_KEY=re_replace_me
QUOTE_FROM_EMAIL=quotes@your-domain.example
