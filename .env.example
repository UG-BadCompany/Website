# Site
SITE_URL=https://ta-contracting.org
SITE_URL_ALIASES=https://tacontracting.netlify.app

# Netlify Database / Postgres
# Netlify Database will provide the actual connection values in Netlify.
# Do not expose database credentials in client-side JavaScript.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Auth provider for the single-login portal (Auth0, Clerk, or another provider)
AUTH_PROVIDER=auth0
AUTH_ISSUER_URL=https://your-auth-domain.example
AUTH_CLIENT_ID=replace-with-client-id
AUTH_CLIENT_SECRET=replace-with-client-secret
AUTH_SESSION_SECRET=replace-with-random-session-secret
AUTH_SESSION_COOKIE_NAME=ta_session
CLIENT_SESSION_TTL_MINUTES=30
STAFF_SESSION_TTL_MINUTES=120
MAGIC_LINK_TTL_MINUTES=20
MAGIC_LINK_FROM_EMAIL=portal@ta-contracting.org

# Payment integrations
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=sq0atp_replace_me
SQUARE_APPLICATION_ID=sq0idp_replace_me
SQUARE_LOCATION_ID=replace-with-square-location-id
SQUARE_WEBHOOK_SIGNATURE_KEY=replace-with-square-webhook-signature-key
SQUARE_API_VERSION=2026-01-22

# Future integrations
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
RESEND_API_KEY=re_replace_me
QUOTE_FROM_EMAIL=quotes@ta-contracting.org
