# Site
SITE_URL=https://your-domain.example

# Supabase client-side auth/database access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Server-only keys for future backend functions/build steps.
# Do not expose this in client-side JavaScript.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Future integrations
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
RESEND_API_KEY=re_replace_me
QUOTE_FROM_EMAIL=quotes@your-domain.example
