# Public deployment URL used for Stripe success/cancel URLs and emailed links.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=job-files
SUPABASE_DOCUMENT_BUCKET=generated-documents

# Resend transactional email.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM="T&A Contracting <quotes@your-domain.example>"
ADMIN_NOTIFICATION_EMAIL=owner@your-domain.example

# Stripe payments.
STRIPE_SECRET_KEY=sk_live_xxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
