# Required server-side variables
OPENAI_API_KEY=
RESEND_API_KEY=
SITE_URL=https://example.com

# Public-safe frontend value only
RECAPTCHA_SITE_KEY=

# Email
MAGIC_LINK_FROM_EMAIL=no-reply@example.com
QUOTE_FROM_EMAIL=quotes@example.com
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# Optional AI models
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PHOTO_MODEL=gpt-4.1-mini
OPENAI_QUOTE_MODEL=gpt-4.1-mini
SERPAPI_API_KEY=

# Square (optional)
SQUARE_ACCESS_TOKEN=
SQUARE_API_VERSION=2025-04-16
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# License server (disabled by default)
LICENSE_SERVER_URL=
LICENSE_SERVER_API_KEY=
LICENSE_VALIDATION_ENABLED=false

# Site aliases
SITE_URL_ALIASES=
RECAPTCHA_SECRET_KEY=
